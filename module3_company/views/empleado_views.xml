<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_empleado_form" model="ir.ui.view">
        <field name="name">module3.empleado.form</field>
        <field name="model">module3.empleado</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Personal Info">
                        <field name="name"/>
                        <field name="age"/>
                        <field name="email"/>
                        <field name="workplace_id"/>
                    </group>
                    <group string="Employment Info">
                        <field name="position"/>
                        <field name="salary"/>
                        <field name="hire_date"/>
                        <field name="empresa_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_empleado_list" model="ir.ui.view">
        <field name="name">module3.empleado.list</field>
        <field name="model">module3.empleado</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="position"/>
                <field name="salary"/>
                <field name="empresa_id"/>
            </list>
        </field>
    </record>

    <record id="action_empleado" model="ir.actions.act_window">
        <field name="name">Empleados</field>
        <field name="res_model">module3.empleado</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_empleado" name="Empleados" parent="menu_module3_root" action="action_empleado"/>
</odoo>