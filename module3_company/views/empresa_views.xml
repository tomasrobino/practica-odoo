<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_empresa_form" model="ir.ui.view">
        <field name="name">module3.empresa.form</field>
        <field name="model">module3.empresa</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Workplace Info">
                        <field name="name"/>
                        <field name="address"/>
                        <field name="capacity"/>
                    </group>
                    <group string="Company Info">
                        <field name="tax_id"/>
                        <field name="industry"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_empresa_list" model="ir.ui.view">
        <field name="name">module3.empresa.list</field>
        <field name="model">module3.empresa</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="address"/>
                <field name="tax_id"/>
                <field name="industry"/>
            </list>
        </field>
    </record>

    <record id="action_empresa" model="ir.actions.act_window">
        <field name="name">Empresas</field>
        <field name="res_model">module3.empresa</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_module3_root" name="Module 3" sequence="30"/>
    <menuitem id="menu_empresa" name="Empresas" parent="menu_module3_root" action="action_empresa"/>
</odoo>