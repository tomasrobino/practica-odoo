<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hospital_form" model="ir.ui.view">
        <field name="name">module2.hospital.form</field>
        <field name="model">module2.hospital</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Workplace Info">
                        <field name="name"/>
                        <field name="address"/>
                        <field name="capacity"/>
                    </group>
                    <group string="Sleep Place Info">
                        <field name="num_beds"/>
                        <field name="floor"/>
                    </group>
                    <group string="Hospital Info">
                        <field name="speciality"/>
                        <field name="emergency_phone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hospital_list" model="ir.ui.view">
        <field name="name">module2.hospital.list</field>
        <field name="model">module2.hospital</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="address"/>
                <field name="speciality"/>
                <field name="emergency_phone"/>
            </list>
        </field>
    </record>

    <record id="action_hospital" model="ir.actions.act_window">
        <field name="name">Hospitals</field>
        <field name="res_model">module2.hospital</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hospital" name="Hospitals" parent="menu_module2_root" action="action_hospital"/>
</odoo>