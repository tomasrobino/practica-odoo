<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend the existing persona form to add paciente fields -->
    <record id="view_paciente_form_inherit" model="ir.ui.view">
        <field name="name">module1.persona.form.inherit.paciente</field>
        <field name="model">module1.persona</field>
        <field name="inherit_id" ref="module1_base.view_persona_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="after">
                <group string="Patient Info">
                    <field name="medical_record"/>
                    <field name="diagnosis"/>
                    <field name="admission_date"/>
                    <field name="hospital_id"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Extend the existing persona list to add paciente fields -->
    <record id="view_paciente_list_inherit" model="ir.ui.view">
        <field name="name">module1.persona.list.inherit.paciente</field>
        <field name="model">module1.persona</field>
        <field name="inherit_id" ref="module1_base.view_persona_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[last()]" position="after">
                <field name="medical_record"/>
                <field name="admission_date"/>
                <field name="hospital_id"/>
            </xpath>
        </field>
    </record>

    <record id="action_paciente" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="res_model">module1.persona</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_module2_root" name="Module 2" sequence="20"/>
    <menuitem id="menu_paciente" name="Pacientes" parent="menu_module2_root" action="action_paciente"/>
</odoo>