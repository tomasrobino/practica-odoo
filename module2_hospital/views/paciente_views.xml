<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_paciente_form" model="ir.ui.view">
        <field name="name">module1.persona.form.paciente</field>
        <field name="model">module1.persona</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="email"/>
                        <field name="workplace_id"/>
                        <field name="medical_record"/>
                        <field name="diagnosis"/>
                        <field name="admission_date"/>
                        <field name="hospital_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_paciente" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="res_model">module1.persona</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_module2_root" name="Module 2" sequence="20"/>
    <menuitem id="menu_paciente" name="Pacientes" parent="menu_module2_root" action="action_paciente"/>
</odoo>